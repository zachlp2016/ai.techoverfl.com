{
	admin off
	email {$ACME_EMAIL:ops@techoverfl.com}
}

{$SITE_ADDRESS:ai.techoverfl.com} {
	encode zstd gzip

	log {
		output stdout
		format json
	}

	header {
		-Server
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "DENY"
	}

	@edge_health path /edge/health
	handle @edge_health {
		header Content-Type "text/plain; charset=utf-8"
		respond "ok\n" 200
	}

	@local_assets path /status /status.html /styles.css /downloads/* /.well-known/*
	handle @local_assets {
		@status path /status
		rewrite @status /status.html
		reverse_proxy dashboard:8080
	}

	handle {
		reverse_proxy {$INTERNAL_APP_UPSTREAM:http://dashboard:8080} {
			health_uri {$INTERNAL_APP_HEALTH_PATH:/health}
			health_interval {$UPSTREAM_HEALTH_INTERVAL:30s}
			health_timeout {$UPSTREAM_HEALTH_TIMEOUT:5s}
			health_fails 2
			health_passes 2

			fail_duration 30s
			max_fails 2
			lb_try_duration 2s
			lb_try_interval 250ms

			transport http {
				dial_timeout 3s
				response_header_timeout 30s
				keepalive 30s
			}

			@upstream_unavailable status 502 503 504
			handle_response @upstream_unavailable {
				rewrite /status.html
				reverse_proxy dashboard:8080 {
					replace_status 503
				}
			}
		}
	}

	handle_errors 502 503 504 {
		rewrite /status.html
		reverse_proxy dashboard:8080 {
			replace_status 503
		}
	}
}
