# Nginx terminates public TLS. Caddy accepts HTTP only on the private Docker
# listener published by Compose to the host loopback interface.
SITE_ADDRESS=:8080
ACME_EMAIL=ops@techoverfl.com

# Dashboard mode is the safe default while the private Rails connection does
# not exist. When WireGuard and Rails are ready, replace the upstream with the
# Rails WireGuard address and change the health path to /up.
INTERNAL_APP_UPSTREAM=http://dashboard:8080
INTERNAL_APP_HEALTH_PATH=/health

# Public utility model routes are sent to this path-restricted Nginx listener
# on secure.techoverfl.com through WireGuard.
UTILITY_GATEWAY_UPSTREAM=http://10.77.0.2:8443

UPSTREAM_HEALTH_INTERVAL=30s
UPSTREAM_HEALTH_TIMEOUT=5s
